// Spot lights
{
    const SLItems: 3
    const SLSpacing: 4.5

    Position3: {175}

    // 0 degree tilt - Red (circle)
    Display(items: SLItems) {
        Position3: {0, 0, -10}
    }
    {
        Position3: {-SLSpacing, 3, -10}
        Rotation3: {-math.PI / 2, 0, 0}
        SpotLight: {intensity: 20, range: 8, inner_angle: 15, outer_angle: 25}
        Rgba: {255, 0, 0}
    }
    {
        Position3: {0, 3, -10}
        Rotation3: {-math.PI / 2, 0, 0}
        SpotLight: {intensity: 50, range: 8, inner_angle: 15, outer_angle: 25}
        Rgba: {255, 0, 0}

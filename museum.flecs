        // Green
        Display(items: LightItems) {
            Position3: {0, 0, -40}

            {
                Position3: {-LightSpacing, 2}
                PointLight: {intensity: 2, range: 12}
                Rgba: {0, 255, 0}
            }
            {
                Position3: {0, 2}
                PointLight: {intensity: 5, range: 12}
                Rgba: {0, 255, 0}
            }
            {
                Position3: {LightSpacing, 2}
                PointLight: {intensity: 10, range: 12}
                Rgba: {0, 255, 0}
            }
        }

        // Cyan
        Display(items: LightItems) {
            Position3: {0, 0, -50}

            {
                Position3: {-LightSpacing, 2}
                PointLight: {intensity: 2, range: 12}
                Rgba: {0, 255, 255}
            }
            {
                Position3: {0, 2}
                PointLight: {intensity: 5, range: 12}
                Rgba: {0, 255, 255}
            }
            {
                Position3: {LightSpacing, 2}
                PointLight: {intensity: 10, range: 12}
                Rgba: {0, 255, 255}
            }
        }

        // Blue
        Display(items: LightItems) {
            Position3: {0, 0, -60}

            {
                Position3: {-LightSpacing, 2}
                PointLight: {intensity: 2, range: 12}
                Rgba: {0, 0, 255}
            }
            {
                Position3: {0, 2}
                PointLight: {intensity: 5, range: 12}
                Rgba: {0, 0, 255}
            }
            {
                Position3: {LightSpacing, 2}
                PointLight: {intensity: 10, range: 12}
                Rgba: {0, 0, 255}
            }
        }

        // Indigo
        Display(items: LightItems) {
            Position3: {0, 0, -70}

            {
                Position3: {-LightSpacing, 2}
                PointLight: {intensity: 2, range: 12}
                Rgba: {75, 0, 130}
            }
            {
                Position3: {0, 2}
                PointLight: {intensity: 5, range: 12}
                Rgba: {75, 0, 130}
            }
            {
                Position3: {LightSpacing, 2}
                PointLight: {intensity: 10, range: 12}
                Rgba: {75, 0, 130}
            }
        }

        // White
        Display(items: LightItems) {
            Position3: {0, 0, -80}

            {
                Position3: {-LightSpacing, 2}
                PointLight: {intensity: 2, range: 12}
                Rgba: {255, 255, 255}
            }
            {
                Position3: {0, 2}
                PointLight: {intensity: 5, range: 12}
                Rgba: {255, 255, 255}
            }
            {
                Position3: {LightSpacing, 2}
                PointLight: {intensity: 10, range: 12}
                Rgba: {255, 255, 255}
            }
        }
    }

    // Spot lights
    {
        Position3: {10}

        // 0 degree tilt - Red (circle)
        Display(items: LightItems) {
            Position3: {0, 0, -10}

            {
                Position3: {-LightSpacing, 3}
                Rotation3: {-math.PI / 2, 0, 0}
                SpotLight: {intensity: 20, range: 8, inner_angle: 15, outer_angle: 25}
                Rgba: {255, 0, 0}
            }
            {
                Position3: {0, 3}
                Rotation3: {-math.PI / 2, 0, 0}
                SpotLight: {intensity: 50, range: 8, inner_angle: 15, outer_angle: 25}
                Rgba: {255, 0, 0}
            }
            {
                Position3: {LightSpacing, 3}
                Rotation3: {-math.PI / 2, 0, 0}
                SpotLight: {intensity: 100, range: 8, inner_angle: 15, outer_angle: 25}
                Rgba: {255, 0, 0}
            }
        }

        // 10 degree tilt - Orange
        Display(items: LightItems) {
            Position3: {0, 0, -20}

            {
                Position3: {-LightSpacing, 3, 0.35}
                Rotation3: {-math.PI / 2 + math.PI / 18, 0, 0}
                SpotLight: {intensity: 20, range: 8, inner_angle: 15, outer_angle: 25}
                Rgba: {255, 128, 0}
            }
            {
                Position3: {0, 3, 0.35}
                Rotation3: {-math.PI / 2 + math.PI / 18, 0, 0}
                SpotLight: {intensity: 50, range: 8, inner_angle: 15, outer_angle: 25}
                Rgba: {255, 128, 0}
            }
            {
                Position3: {LightSpacing, 3, 0.35}
                Rotation3: {-math.PI / 2 + math.PI / 18, 0, 0}
                SpotLight: {intensity: 100, range: 8, inner_angle: 15, outer_angle: 25}
                Rgba: {255, 128, 0}
            }
        }

        // 20 degree tilt - Yellow
        Display(items: LightItems) {
            Position3: {0, 0, -30}

            {
                Position3: {-LightSpacing, 3, 0.73}
                Rotation3: {-math.PI / 2 + math.PI / 9, 0, 0}
                SpotLight: {intensity: 20, range: 8, inner_angle: 14, outer_angle: 24}
                Rgba: {255, 255, 0}
            }
            {
                Position3: {0, 3, 0.73}
                Rotation3: {-math.PI / 2 + math.PI / 9, 0, 0}
                SpotLight: {intensity: 50, range: 8, inner_angle: 14, outer_angle: 24}
                Rgba: {255, 255, 0}
            }
            {
                Position3: {LightSpacing, 3, 0.73}
                Rotation3: {-math.PI / 2 + math.PI / 9, 0, 0}
                SpotLight: {intensity: 100, range: 8, inner_angle: 14, outer_angle: 24}
                Rgba: {255, 255, 0}
            }
        }

        // 30 degree tilt - Green
        Display(items: LightItems) {
            Position3: {0, 0, -40}

            {
                Position3: {-LightSpacing, 3, 1.15}
                Rotation3: {-math.PI / 2 + math.PI / 6, 0, 0}
                SpotLight: {intensity: 25, range: 8, inner_angle: 13, outer_angle: 22}
                Rgba: {0, 255, 0}
            }
            {
                Position3: {0, 3, 1.15}
                Rotation3: {-math.PI / 2 + math.PI / 6, 0, 0}
                SpotLight: {intensity: 60, range: 8, inner_angle: 13, outer_angle: 22}
                Rgba: {0, 255, 0}
            }
            {
                Position3: {LightSpacing, 3, 1.15}
                Rotation3: {-math.PI / 2 + math.PI / 6, 0, 0}
                SpotLight: {intensity: 125, range: 8, inner_angle: 13, outer_angle: 22}
                Rgba: {0, 255, 0}
            }
        }

        // 40 degree tilt - Cyan
        Display(items: LightItems) {
            Position3: {0, 0, -50}

            {
                Position3: {-LightSpacing, 3, 1.68}
                Rotation3: {-math.PI / 2 + 2 * math.PI / 9, 0, 0}
                SpotLight: {intensity: 30, range: 8, inner_angle: 12, outer_angle: 20}
                Rgba: {0, 255, 255}
            }
            {
                Position3: {0, 3, 1.68}
                Rotation3: {-math.PI / 2 + 2 * math.PI / 9, 0, 0}
                SpotLight: {intensity: 75, range: 8, inner_angle: 12, outer_angle: 20}
                Rgba: {0, 255, 255}
            }
            {
                Position3: {LightSpacing, 3, 1.68}
                Rotation3: {-math.PI / 2 + 2 * math.PI / 9, 0, 0}
                SpotLight: {intensity: 150, range: 8, inner_angle: 12, outer_angle: 20}
                Rgba: {0, 255, 255}
            }
        }

        // 50 degree tilt - Blue
        Display(items: LightItems) {
            Position3: {0, 0, -60}

            {
                Position3: {-LightSpacing, 3, 2.38}
                Rotation3: {-math.PI / 2 + 5 * math.PI / 18, 0, 0}

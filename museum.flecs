    {
        Position3: {SLSpacing, 3, -74.51}
        Rotation3: {-math.PI / 2 + 7 * math.PI / 18, 0, 0}
        SpotLight: {intensity: 750, range: 12, inner_angle: 5, outer_angle: 9}
        Rgba: {255, 255, 255}
    }
}

materials {
    prefab dielectricRoughWhite {
        PbrMaterial: {metallic: 0, roughness: 1}
        Rgba: {255, 255, 255}
    }
    prefab dielectricSmoothWhite {
        PbrMaterial: {metallic: 0, roughness: 0}
        Rgba: {255, 255, 255}
    }
    prefab metalRoughWhite {
        PbrMaterial: {metallic: 1, roughness: 1}
        Rgba: {255, 255, 255}
    }
    prefab metalSmoothWhite {
        PbrMaterial: {metallic: 1, roughness: 0}
        Rgba: {255, 255, 255}
    }
    prefab dielectricRoughBlack {
        PbrMaterial: {metallic: 0, roughness: 1}
        Rgba: {1, 1, 1}
    }
    prefab dielectricSmoothBlack {
        PbrMaterial: {metallic: 0, roughness: 0}
        Rgba: {1, 1, 1}
    }
    prefab metalRoughBlack {
        PbrMaterial: {metallic: 1, roughness: 1}
        Rgba: {1, 1, 1}
    }
    prefab metalSmoothBlack {
        PbrMaterial: {metallic: 1, roughness: 0}
        Rgba: {1, 1, 1}
    }
}

// Spheres
{
    Position3: {-50}

    for i in 0..8 {
        Display(items: ItemCount) {
            Position3: {0, 0, -((1 + i) * 10)}

            {
                Position3: {x: -ItemSpacing * (ItemCount / 2 - 0.5), y: ItemSize}

                with AngularVelocity3(0, 1, 0), Sphere(segments: i + 3, radius: ItemSize / 2) {{
                    (IsA, materials.dielectricRoughWhite)
                    Position3: {0 * ItemSpacing}
                } {
                    (IsA, materials.dielectricSmoothWhite)
                    Position3: {1 * ItemSpacing}
                } {
                    (IsA, materials.metalRoughWhite)
                    Position3: {2 * ItemSpacing}
                } {
                    (IsA, materials.metalSmoothWhite)
                    Position3: {3 * ItemSpacing}

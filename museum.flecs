// Beveled Boxes
{
    Position3: {100, z: -200}

    for i in 0..8 {
        Display(items: ItemCount) {
            Position3: {0, 0, -((1 + i) * 10)}

            {
                Position3: {x: -ItemSpacing * (ItemCount / 2 - 0.5), y: ItemSize}

                with Box(ItemSize, ItemSize, ItemSize) {{
                    (IsA, materials.dielectricRoughWhite)
                    Bevel: {segments: 1, smooth: false, radius: 0.1 + i * 0.15}
                    Position3: {0 * ItemSpacing}
                } {
                    (IsA, materials.dielectricSmoothWhite)
                    Bevel: {segments: 2, smooth: false, radius: 0.1 + i * 0.15}
                    Position3: {1 * ItemSpacing}
                } {
                    (IsA, materials.metalRoughWhite)
                    Bevel: {segments: 3, smooth: false, radius: 0.1 + i * 0.15}
                    Position3: {2 * ItemSpacing}
                } {
                    (IsA, materials.metalSmoothWhite)
                    Bevel: {segments: 4, smooth: false, radius: 0.1 + i * 0.15}
                    Position3: {3 * ItemSpacing}
                } {
                    (IsA, materials.dielectricRoughBlack)
                    Bevel: {segments: 5, smooth: true, radius: 0.1 + i * 0.15}
                    Position3: {4 * ItemSpacing}
                } {
                    (IsA, materials.dielectricSmoothBlack)
                    Bevel: {segments: 6, smooth: true, radius: 0.1 + i * 0.15}
                    Position3: {5 * ItemSpacing}
                } {
                    (IsA, materials.metalRoughBlack)
                    Bevel: {segments: 7, smooth: true, radius: 0.1 + i * 0.15}
                    Position3: {6 * ItemSpacing}
                } {
                    (IsA, materials.metalSmoothBlack)
                    Bevel: {segments: 8, smooth: true, radius: 0.1 + i * 0.15}
                    Position3: {7 * ItemSpacing}
                }}
            }
        }
    }
}


// Lights
{
    const LightItems: 3
    const LightSpacing: 4.5

    Position3: {150}

    {
        Position3: {-10}

        // Red
        Display(items: LightItems) {
            Position3: {0, 0, -10}

            {
                Position3: {-LightSpacing, 2}
                PointLight: {intensity: 2, range: 12}
                Rgba: {255, 0, 0}
            }
            {
                Position3: {0, 2}
                PointLight: {intensity: 5, range: 12}
                Rgba: {255, 0, 0}
            }
            {
                Position3: {LightSpacing, 2}
                PointLight: {intensity: 10, range: 12}
                Rgba: {255, 0, 0}
            }
        }

        // Orange
        Display(items: LightItems) {
            Position3: {0, 0, -20}

            {
                Position3: {-LightSpacing, 2}
                PointLight: {intensity: 2, range: 12}
                Rgba: {255, 128, 0}
            }
            {
                Position3: {0, 2}
                PointLight: {intensity: 5, range: 12}
                Rgba: {255, 128, 0}
            }
            {
                Position3: {LightSpacing, 2}
                PointLight: {intensity: 10, range: 12}
                Rgba: {255, 128, 0}
            }
        }

        // Yellow
        Display(items: LightItems) {
            Position3: {0, 0, -30}

            {
                Position3: {-LightSpacing, 2}
                PointLight: {intensity: 2, range: 12}
                Rgba: {255, 255, 0}
            }
            {
                Position3: {0, 2}
                PointLight: {intensity: 5, range: 12}
                Rgba: {255, 255, 0}
            }
            {
                Position3: {LightSpacing, 2}
                PointLight: {intensity: 10, range: 12}
                Rgba: {255, 255, 0}
            }

            }
        }

        // 70 degree tilt - White
        Display(items: LightItems) {
            Position3: {0, 0, -20}

            {
                Position3: {-LightSpacing, 0.75, 1.3725}
                Rotation3: {-math.PI / 2 + 7 * math.PI / 18, 0, 0}
                SpotLight: {intensity: 9.375, range: 3, inner_angle: 5, outer_angle: 9}
                Rgba: {255, 255, 255}
            }
            {
                Position3: {0, 0.75, 1.3725}
                Rotation3: {-math.PI / 2 + 7 * math.PI / 18, 0, 0}
                SpotLight: {intensity: 23.4375, range: 3, inner_angle: 5, outer_angle: 9}
                Rgba: {255, 255, 255}
            }
            {
                Position3: {LightSpacing, 0.75, 1.3725}
                Rotation3: {-math.PI / 2 + 7 * math.PI / 18, 0, 0}
                SpotLight: {intensity: 46.875, range: 3, inner_angle: 5, outer_angle: 9}
                Rgba: {255, 255, 255}
            }
        }
    }
}

materials {
    prefab dielectricRoughWhite {
        PbrMaterial: {metallic: 0, roughness: 1}
        Rgba: {255, 255, 255}
    }
    prefab dielectricSmoothWhite {
        PbrMaterial: {metallic: 0, roughness: 0}
        Rgba: {255, 255, 255}
    }
    prefab metalRoughWhite {
        PbrMaterial: {metallic: 1, roughness: 1}
        Rgba: {255, 255, 255}
    }
    prefab metalSmoothWhite {
        PbrMaterial: {metallic: 1, roughness: 0}
        Rgba: {255, 255, 255}
    }
    prefab dielectricRoughBlack {
        PbrMaterial: {metallic: 0, roughness: 1}
        Rgba: {1, 1, 1}
    }
    prefab dielectricSmoothBlack {
        PbrMaterial: {metallic: 0, roughness: 0}
        Rgba: {1, 1, 1}
    }
    prefab metalRoughBlack {
        PbrMaterial: {metallic: 1, roughness: 1}
        Rgba: {1, 1, 1}
    }
    prefab metalSmoothBlack {
        PbrMaterial: {metallic: 1, roughness: 0}
        Rgba: {1, 1, 1}
    }
}


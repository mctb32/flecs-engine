@tree Parent
template ForestBlock {
  for tx in 0..12 {
    for tz in 0..8 {
      const treeX = tx * 0.325 + 0.75
      const treeZ = tz * 0.3 + 0.85
      const pick = rng.u(3)
      if pick == 1 {
        _ : prefabs.tree_small {
          Position3: {treeX, 0, treeZ}
        }
      }
      if pick == 2 {
        _ : prefabs.tree_large {
          Position3: {treeX, 0, treeZ}
        }
      }
    }
  }
}

@tree Parent
template IndustrialBlock {
  for i in 0..2 {
    const bx = 1.75 + i * 2.0

    RandomIndustrial() {
      Position3: {bx, 0, 1.5}
    }

    RandomIndustrial() {
      Position3: {bx, 0, 2.5}
      Rotation3: {0, math.PI, 0}
    }
  }
}

@tree Parent
template LowDensityBlock {
  for i in 0..2 {
    const bx = (i + 1) * 1.8

    RandomSuburban() {
      Position3: {bx, 0, 1.25}
    }

    RandomSuburban() {
      Position3: {bx, 0, 2.75}
      Rotation3: {0, math.PI, 0}
    }
  }

  for i in 0..6 {
    _ : prefabs.fence {
      Position3: {2.75, 0, 0.75 + i * 0.4}
      Rotation3: {0, math.PI / 2, 0}
    }
  }

  for z in 0..8 {
    _ : prefabs.tree_small {
      Position3: {0.75, 0, 0.75 + z * 0.3}
    }
    _ : prefabs.tree_small {
      Position3: {4.75, 0, 0.75 + z * 0.3}
    }
  }
}

@tree Parent
template MediumDensityBlock {
  for i in 0..5 {
    const bx = (i + 1) * 0.9

    RandomCommercial() {
      Position3: {bx, 0, 1.0}
    }

    RandomCommercial() {
      Position3: {bx, 0, 3.0}
      Rotation3: {0, math.PI, 0}
    }

    _ : prefabs.tree_large {
      Position3: {bx, 0, 1.75}
    }
    _ : prefabs.tree_large {
      Position3: {bx, 0, 2.25}
    }
  }

  for i in 0..10 {
    const px = 0.75 + i * 0.4

    _ : prefabs.path_stones {
      Position3: {px, 0.02, 2.0}
      Scale3: {1, 2, 1}
      Rotation3: {0, math.PI / 2, 0}
    }
    _ : prefabs.fence {
      Position3: {px, 0.02, 1.85}
    }
    _ : prefabs.fence {
      Position3: {px, 0.02, 2.15}
    }
  }
}

@tree Parent
template HighDensityBlock {
  for i in 0..3 {
    const bx = 1.25 + i * 1.5

    RandomSkyscraper() {
      Position3: {bx, 0, 1.25}
    }

    RandomSkyscraper() {
      Position3: {bx, 0, 2.75}
      Rotation3: {0, math.PI, 0}
    }
  }
}

template KenneyCity {
  prop gridSize: 100

  const gridSizeH = gridSize / 2

  for x in 0..gridSize {
    for z in 0..gridSize {
      const xR = x - gridSizeH
      const zR = z - gridSizeH
      const xP = xR * 5.5
      const zP = zR * 4.0

      _ : prefabs.crossroad {
        Position3: {xP, 0, zP}
      }

      _ : prefabs.road_straight {
        Position3: {xP + 2.75, 0, zP}
        Scale3: {4.5, 1, 1}
      }

      _ : prefabs.road_straight {
        Position3: {xP, 0, zP + 2.0}
        Scale3: {3.0, 1, 1}
        Rotation3: {0, math.PI / 2, 0}
      }

      _ : prefabs.ground_tile {
        Position3: {xP + 2.75, 0, zP + 2.0}
        Scale3: {4.5, 1, 3}
      }

      const density = math.perlin2(xP * 0.025, zP * 0.025) * 0.5 + 0.5

      if density < 0.25 {
        IndustrialBlock() {
          Position3: {xP, 0, zP}
        }
      }
      if density >= 0.25 {
        if density < 0.4 {
          ForestBlock() {
            Position3: {xP, 0, zP}
          }
        }
      }
      if density >= 0.4 {
        if density < 0.6 {
          LowDensityBlock() {
            Position3: {xP, 0, zP}
          }
        }
      }
      if density >= 0.6 {
        if density < 0.7 {
          MediumDensityBlock() {
            Position3: {xP, 0, zP}
          }
        }
      }
      if density >= 0.7 {
        HighDensityBlock() {
          Position3: {xP, 0, zP}
        }
      }
    }
  }
}

KenneyCity city() {
  Position3: {}
}

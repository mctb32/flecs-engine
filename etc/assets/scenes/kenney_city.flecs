@tree Parent
template RandomSuburban {
  const p = rng.u(12)
  if p == 0 {
    _ : prefabs.suburban_b {}
  } else if p == 1 {
    _ : prefabs.suburban_c {}
  } else if p == 2 {
    _ : prefabs.suburban_d {}
  } else if p == 3 {
    _ : prefabs.suburban_e {}
  } else if p == 4 {
    _ : prefabs.suburban_f {}
  } else if p == 5 {
    _ : prefabs.suburban_g {}
  } else if p == 6 {
    _ : prefabs.suburban_h {}
  } else if p == 7 {
    _ : prefabs.suburban_i {}
  } else if p == 8 {
    _ : prefabs.suburban_k {}
  } else if p == 9 {
    _ : prefabs.suburban_l {}
  } else if p == 10 {
    _ : prefabs.suburban_o {}
  } else if p == 11 {
    _ : prefabs.suburban_u {}
  }
}

@tree Parent
